{
  "name": "ai-idea-hunter",
  "version": "1.2.1",
  "private": true,
  "type": "module",
  "description": "A local-first opportunity workspace for evidence-backed AI software ideas.",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "check": "node scripts/check.mjs",
    "discovery:fixture": "node scripts/collect-opportunities.mjs --fixture tests/fixtures/discovery-signals.json --output .tmp/discovery.json --no-ai",
    "dev": "node scripts/dev-server.mjs",
    "test": "node --test",
    "test:all": "npm run check && npm test"
  },
  "license": "MIT"
}
